.ruff_cache/
.coverage
htmlcov/

# Ignore Git files and local docs
.git/
.github/
docs/
/README.md
/LICENSE
/CODE_OF_CONDUCT.md
/CONTRIBUTING.md
/SECURITY.md

# Ignore local databases and configuration files
*.db
*.sqlite
*.sqlite3
.env
.env.*

# Ignore logs
*.log
logs/
